# ════════════════════════════════════════════════
# ec-search-api 環境変数サンプル【v8.01】
# ════════════════════════════════════════════════
# ⚠️ このファイルをコピして .env を作成してください
# ⚠️ .env は .gitignore で除外済み → GitHubにpushしないこと
# ⚠️ 本番値は Cloud Run の環境変数（--update-env-vars）に設定すること

# ── Yahoo!ショッピング API ──────────────────────
YAHOO_CLIENT_ID="your-yahoo-client-id"
YAHOO_AFFILIATE_TYPE="vc"
YAHOO_AFFILIATE_ID="your-yahoo-affiliate-id"

# ── 楽天市場 API（v8.01: 新基盤 2026年版）──────
# ⚠️ APPLICATION_ID は UUID形式（ハイフンあり）で設定すること
# ⚠️ ACCESS_KEY は2026年新APIから必須（これがないと403になる）
RAKUTEN_APPLICATION_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
RAKUTEN_ACCESS_KEY="your-rakuten-access-key"
RAKUTEN_AFFILIATE_ID="your-rakuten-affiliate-id"

# ── Ollama（Oracle VM / Tailscale経由）─────────
# Tailscaleプライベートトンネル経由のみ（外部非公開）
OLLAMA_ENDPOINT="http://100.92.194.114:11434/api/chat"
OLLAMA_MODEL="qwen2.5:14b"

# ── Amazon アフィリエイト ───────────────────────
# SearXNG経由で取得（PA-APIは不使用）
AMAZON_AFFILIATE_TAG="ggvssyakumo-22"

# ════════════════════════════════════════════════
# 廃止済み変数（v8.01で不要になったもの）
# ════════════════════════════════════════════════
# GEMINI_API_KEY  → Ollama（qwen2.5:14b）に換装済み・不要
# APP_URL         → Cloud Runが自動注入・不要
# GOOGLE_CLIENT_ID → Googleログイン廃止・不要
